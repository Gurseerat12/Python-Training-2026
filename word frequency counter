text = input("Enter a passage: ")

words = text.split()
count = {}
for word in words:
    if word in count:
        count[word] += 1
    else:
        count[word] = 1

top5 = sorted(count.items(), key=lambda x: x[1], reverse=True)

print("Top 5 Words:")
for word, freq in top5[:5]:
    print(word, ":", freq)

students = {
    "Arsh": 85,
    "Simran": 92,
    "Aman": 78,
    "Karan": 88
}

total = 0

for mark in students.values():
    total += mark

average = total / len(students)

topper = max(students, key=students.get)

grades = [
    "A" if m >= 90 else
    "B" if m >= 80 else
    "C" if m >= 70 else
    "D"
    for m in students.values()
]

print("Average Marks:", average)
print("Topper:", topper)

print("\nGrades:")
i = 0
for name in students:
    print(name, ":", grades[i])
    i += 1
